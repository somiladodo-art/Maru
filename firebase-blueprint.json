{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A user who completed the quiz and provided their email to claim points.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lead was created."
        },
        "tier": {
          "type": "string",
          "description": "The tier they qualified for."
        },
        "estimatedEarnings": {
          "type": "number",
          "description": "The maximum estimated earnings."
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Stores leads who provided their email."
    }
  }
}
